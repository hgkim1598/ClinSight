# ClinSight 환경변수 템플릿.
# 실제 값은 `.env` 에 채우고, .env 는 커밋하지 않는다 (.gitignore 처리됨).

# API 베이스 URL. mock 모드일 때는 비워두거나 무시된다.
VITE_API_BASE=

# Mock 모드 토글.
# - true  : api/mock 데이터 사용, 로그인 없이 동작
# - false : 실제 API 호출 + Cognito 로그인 필수
VITE_USE_MOCK=true

# AWS Cognito (SPA / Public Client, Client Secret 없음)
VITE_COGNITO_REGION=ap-northeast-2
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=
